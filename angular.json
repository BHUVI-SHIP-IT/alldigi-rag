{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "apps",
  "projects": {
    "admin": {
      "projectType": "application",
      "root": "apps/admin",
      "sourceRoot": "apps/admin/src",
      "prefix": "rag-admin",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/admin",
            "index": "apps/admin/src/index.html",
            "browser": "apps/admin/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/admin/tsconfig.app.json",
            "assets": [
              "apps/admin/src/favicon.ico",
              "apps/admin/src/assets",
              {
                "glob": "**/*",
                "input": "alldigi photo",
                "output": "assets/brand"
              }
            ],
            "styles": ["apps/admin/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "650kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "8kB", "maximumError": "14kB" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": { "buildTarget": "admin:build:production" },
            "development": { "buildTarget": "admin:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "karmaConfig": "karma.conf.js",
            "tsConfig": "apps/admin/tsconfig.spec.json",
            "assets": ["apps/admin/src/assets"],
            "styles": ["apps/admin/src/styles.css"]
          }
        }
      }
    },
    "employee": {
      "projectType": "application",
      "root": "apps/employee",
      "sourceRoot": "apps/employee/src",
      "prefix": "rag-employee",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/employee",
            "index": "apps/employee/src/index.html",
            "browser": "apps/employee/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/employee/tsconfig.app.json",
            "assets": [
              "apps/employee/src/favicon.ico",
              "apps/employee/src/assets",
              {
                "glob": "**/*",
                "input": "alldigi photo",
                "output": "assets/brand"
              }
            ],
            "styles": ["apps/employee/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "650kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "8kB", "maximumError": "14kB" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": { "buildTarget": "employee:build:production" },
            "development": { "buildTarget": "employee:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "karmaConfig": "karma.conf.js",
            "tsConfig": "apps/employee/tsconfig.spec.json",
            "assets": ["apps/employee/src/assets"],
            "styles": ["apps/employee/src/styles.css"]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
