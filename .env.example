# =============================================================================
# PostgreSQL — relational database for users, documents, chunks, and audit logs
# =============================================================================
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=ragdb

# =============================================================================
# MinIO — S3-compatible object storage for uploaded documents
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# =============================================================================
# JWT — JSON Web Token signing and expiry configuration
# Must be at least 32 characters long for HS256 security
# =============================================================================
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_EXPIRY_MINUTES=480

# =============================================================================
# Admin seed — initial admin user created on first startup
# =============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme_admin_password

# =============================================================================
# LLM model — llama.cpp GGUF model to download and serve
# MODEL_URL: full URL to the .gguf file (leave empty to skip download)
# MODEL_FILE: local filename under /models/ inside the llm container
# N_CTX: context window size in tokens
# N_THREADS: CPU threads for inference
# =============================================================================
MODEL_URL=https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF/resolve/main/Llama-3.2-3B-Instruct-Q4_K_M.gguf
MODEL_FILE=llama-3.2-3b-instruct-q4_k_m.gguf
N_CTX=4096
N_THREADS=4

# =============================================================================
# Cache — Redis semantic cache TTL for RAG query results
# CACHE_TTL_DAYS: how many days a cached answer is retained before expiry
# =============================================================================
CACHE_TTL_DAYS=7
